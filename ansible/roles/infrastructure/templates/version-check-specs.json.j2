{# Rendered registry of services tracked by version-check.py. Shape:
     name           -- display title (e.g. "Gatus", "Keycloak")
     current_source -- kind + ident + (for binary) version regex:
       ("swarm",    <service-name>)
       ("container", <name-regex>)
       ("binary",   [argv...], <version-regex>)
     upstream       -- ("github", <repo>) | ("dockerhub", <repo>, <tag-regex>)
     upstream_url   -- human-readable changelog URL
  JSON encoded -- Python reads with `json.load`. Per-host values
  (compose-name regexes) rendered here so the script can stay plain
  Python under scripts/. -#}
[
  {
    "name": "Dokploy",
    "current_source": ["swarm", "dokploy"],
    "upstream": ["github", "Dokploy/dokploy"],
    "upstream_url": "https://github.com/Dokploy/dokploy/releases"
  },
  {
    "name": "Keycloak",
    "current_source": ["container", "{{ keycloak_compose_name | default('keycloak') }}-[a-z0-9]+-server-1"],
    "upstream": ["github", "phasetwo-org/phasetwo-containers"],
    "upstream_url": "https://github.com/phasetwo-org/phasetwo-containers/releases"
  },
  {# Traefik intentionally NOT tracked here. Dokploy installs + owns its
     Traefik container (pinned to an exact tag like `traefik:v3.6.13` in
     Dokploy's own installer). Displaying drift on a Gatus card would
     imply catena can apply the bump -- it can't: Dokploy stomps the
     image tag on its next upgrade, and bumping it out-of-band can
     de-sync Dokploy's dashboard from the live container. Traefik
     updates arrive with Dokploy upgrades (already surfaced as "Dokploy"
     drift on the Versions panel). If a Traefik CVE needs
     out-of-band patching, run `docker pull` + `docker restart` by hand. #}
  {# Keycloak's database is dokploy-postgres (shared with Dokploy + every
     per-app Postgres lives in its own container too); no separate
     Postgres-for-Keycloak container exists, so we don't track one
     independently here. #}
  {
    "name": "Gatus",
    "current_source": ["container", "^{{ gatus_compose_name }}-[a-z0-9]+-app-1$"],
    "upstream": ["github", "TwiN/gatus"],
    "upstream_url": "https://github.com/TwiN/gatus/releases"
  },
  {# No OliveTin / Homepage entries: both are superseded by catena-admin
     (the Go shell), which is first-party and version-tracked via the
     catena release, not a third-party upstream. -#}
  {
    "name": "Healthchecks",
    "current_source": ["container", "^{{ healthchecks_compose_name }}-[a-z0-9]+-app-1$"],
    "upstream": ["github", "healthchecks/healthchecks"],
    "upstream_url": "https://github.com/healthchecks/healthchecks/releases"
  },
  {
    "name": "Cloudflared",
    "current_source": ["swarm", "cloudflared"],
    "upstream": ["github", "cloudflare/cloudflared"],
    "upstream_url": "https://github.com/cloudflare/cloudflared/releases"
  },
  {
    "name": "Restic",
    "current_source": ["binary", ["/usr/local/bin/restic", "version"], "restic (\\S+)"],
    "upstream": ["github", "restic/restic"],
    "upstream_url": "https://github.com/restic/restic/releases"
  }{% if beszel_enabled | default(false) %},
  {# Only tracked when the monitor is deployed; the hub container is
     absent otherwise and version-check would report it unknown. #}
  {
    "name": "Beszel",
    "current_source": ["container", "^{{ beszel_hub_compose_name }}-[a-z0-9]+-app-1$"],
    "upstream": ["github", "henrygd/beszel"],
    "upstream_url": "https://github.com/henrygd/beszel/releases"
  }{% endif %}

]
