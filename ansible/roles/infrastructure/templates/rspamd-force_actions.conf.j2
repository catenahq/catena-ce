# {{ ansible_managed }}
# rspamd force_actions -> fail-loud when the antivirus scan could not
# run. The antivirus module sets CLAM_VIRUS_FAIL when clamd is
# unreachable/errors; rather than deliver the message unscanned
# (fail-open) we SOFT REJECT it -- a 4xx temp-defer, so the sending MTA
# retries and the message is scanned once clamd is back. No mail is lost
# and nothing is delivered unscanned. Pairs with the Step-7 clamav:3310
# probe (which pages the operator) so an AV outage is both contained and
# visible. Dropped into the dms container's rspamd/local.d/ by
# roles/infrastructure mailserver_filtering.yml.
rules {
  CLAM_FAIL_SOFT_REJECT {
    action = "soft reject";
    expression = "CLAM_VIRUS_FAIL";
    message = "Antivirus scan temporarily unavailable; please retry later";
  }
}
