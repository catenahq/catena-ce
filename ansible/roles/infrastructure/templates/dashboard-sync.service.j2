# {{ ansible_managed }}
[Unit]
Description=Regenerate Homepage services.yaml from Dokploy API
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
EnvironmentFile={{ dashboard_sync_env_path }}
ExecStart={{ dashboard_sync_script_path }}
# Avoid flooding journal when nothing changed.
StandardOutput=journal
StandardError=journal
