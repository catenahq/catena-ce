# {{ ansible_managed }}
# Sourced by /usr/local/bin/run-clamav-watch. Pings the self-hosted
# Healthchecks loopback so a down shared clamd pages -- but only when a
# consumer (dms or Nextcloud) is up. Empty HC_PING_KEY = no-op.
HEALTHCHECKS_LOOPBACK_PORT={{ healthchecks_host_localhost_port }}
HC_PING_KEY={{ vault_healthchecks_ping_key | default('') }}
CLAMAV_WATCH_SLUG={{ clamav_watch_slug }}
