# {{ ansible_managed }}
# Config for /usr/local/bin/dashboard-sync. This file is 0600 root:root --
# it contains the Dokploy API key.
#
# Phase 4b retired the Homepage services.yaml writer; the env vars
# below now drive ONLY the gate-route auto-discovery path. The
# catena-admin Apps tab reads the Dokploy API live at request time
# and does not need a precomputed YAML.
DOKPLOY_API_BASE={{ dokploy_api_base }}
DOKPLOY_API_KEY={{ vault_dokploy_api_key }}
DOKPLOY_INFRA_PROJECT={{ dokploy_project_name }}

# Gate-route auto-discovery. dashboard-sync writes Traefik file-based
# routes for every non-infra Dokploy compose/application with a domain.
# Always on -- no opt-out flag (ungated = fully public). Convention for
# backend resolution: the compose MUST expose a dokploy-network alias
# matching its appName (otherwise Traefik cannot resolve the backend
# host and the public URL returns 502).
#
# Per-app posture is read from compose labels (vps.auth.mode):
#   - public     -> single router, force-https only
#   - admin-only -> two routers, oauth2-proxy-admin chain (admin group)
#   - private    -> two routers, oauth2-proxy-staff chain (staff or admin)
# The middleware names below are defined in
# roles/oauth2_proxy/templates/oauth2-proxy-middlewares.yml.j2.
TRAEFIK_DYNAMIC_DIR={{ dokploy_traefik_dynamic_dir }}
AUTH_HOSTNAME={{ keycloak_hostname }}
INFRA_COMPOSE_NAMES={{ gatus_compose_name }},{{ healthchecks_compose_name }},{{ keycloak_compose_name }},{{ recovery_compose_name }}
AUTH_FORCE_HTTPS_MW=oauth2-force-https-proto

# --- Per-app oauth2-proxy provisioning (default-deny enforcement) ---
# dashboard-sync provisions ONE oauth2-proxy instance per gated client
# app in a dedicated `oauth2-proxy-clients` Dokploy compose (the infra
# proxies stay Ansible-managed in the `oauth2-proxy` compose). The flags
# mirror roles/oauth2_proxy/templates/oauth2-proxy.compose.yml.j2 so a
# client app's proxy behaves identically to an infra one, differing only
# in --allowed-group (from the app's vps.auth.groups) and --upstream.
CLOUDFLARE_ZONE={{ cloudflare_zone }}
OAUTH2_PROXY_CLIENTS_COMPOSE=oauth2-proxy-clients
OAUTH2_PROXY_IMAGE={{ oauth2_proxy_image }}
OAUTH2_PROXY_INTERNAL_PORT={{ oauth2_proxy_internal_port }}
OAUTH2_PROXY_COOKIE_NAME={{ oauth2_proxy_cookie_name }}
OAUTH2_PROXY_OIDC_ISSUER={{ oauth2_proxy_oidc_issuer }}
OAUTH2_PROXY_CLIENT_ID={{ oauth2_proxy_client_id }}
OAUTH2_PROXY_CLIENT_SECRET={{ vault_oauth2_proxy_client_secret }}
OAUTH2_PROXY_COOKIE_SECRET={{ vault_oauth2_proxy_cookie_secret }}

# --- Keycloak redirect-URI sync (manage-clients service account) ---
# dashboard-sync UNIONs each gated client host's /oauth2/callback into
# the shared oauth2-proxy client's redirectUris (never removes), using a
# client-credentials token from the `dashboard-sync` service account
# (scoped to realm-management:manage-clients). Empty secret => the sync
# is skipped (the client app's login fails until the operator adds the
# key + re-converges); everything else still provisions.
KEYCLOAK_TOKEN_URL=https://{{ keycloak_hostname }}/realms/{{ keycloak_realm }}/protocol/openid-connect/token
KEYCLOAK_CLIENTS_API=https://{{ keycloak_hostname }}/admin/realms/{{ keycloak_realm }}/clients
DASHBOARD_SYNC_CLIENT_ID=dashboard-sync
DASHBOARD_SYNC_CLIENT_SECRET={{ vault_dashboard_sync_client_secret | default('') }}
