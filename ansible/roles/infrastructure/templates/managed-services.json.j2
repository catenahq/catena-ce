{# {{ ansible_managed }}
   Registry of services the managed-bump engine is allowed to touch.
   Consumed by /usr/local/bin/catena-stack-update-managed on the
   weekly timer. Client-deployed composes are discovered dynamically
   via the Dokploy API and are NOT listed here.

   Each entry:
     name           -- state-file key + log tag
     kind           -- infra-compose | infra-swarm
     compose_name   -- Dokploy appName (for infra-compose only)
     swarm_service  -- docker swarm service name (for infra-swarm only)
     service_key    -- key inside the compose's `services:` dict whose
                      `image:` field is the tag we bump
     upstream.source -- github | dockerhub | quay | docker.elastic.co
     upstream.repo   -- repo slug (e.g. "TwiN/gatus",
                                   "library/postgres",
                                   "oauth2-proxy/oauth2-proxy")
     upstream.tag_pattern (optional) -- regex to filter releases (e.g.
                      "16\\..*-alpine" to lock Postgres to the 16 line)
     upstream.scheme (optional) -- semver | partial_line | build_suffix
                      Default semver. partial_line admits X.Y as well
                      as X.Y.Z (postgres `16.13-alpine` shape).
                      build_suffix compares 4-tuples with the trailing
                      -NNNN as the build increment (zammad shape).

   See automation/helpers/managed_services_overrides.py for the
   matching client-side override registry. See
   automation/helpers/version_policy.py for the comparator contract.
-#}
[
  {
    "name": "gatus",
    "kind": "infra-compose",
    "compose_name": {{ gatus_compose_name | to_json }},
    "service_key": "app",
    "upstream": {
      "source": "github",
      "repo": "TwiN/gatus",
      "tag_pattern": "^v?\\d+\\.\\d+\\.\\d+$"
    }
  },
  {# OliveTin + Homepage retired during the 2026-05-15 post-migration
     audit (catena-admin superseded both). Their task files
     (olivetin.yml, homepage.yml) were removed from
     roles/infrastructure/tasks/; the *_compose_name vars they relied on
     no longer exist. Keeping their entries here broke first-converge
     rendering with `'olivetin_compose_name' is undefined`. -#}
  {
    "name": "healthchecks",
    "kind": "infra-compose",
    "compose_name": {{ healthchecks_compose_name | to_json }},
    "service_key": "app",
    "upstream": {
      "source": "dockerhub",
      "repo": "healthchecks/healthchecks",
      "tag_pattern": "^v\\d+\\.\\d+(?:\\.\\d+)?$",
      "scheme": "partial_line"
    }
  },
  {
    "name": "cloudflared",
    "kind": "infra-swarm",
    "swarm_service": "cloudflared",
    "upstream": {
      "source": "github",
      "repo": "cloudflare/cloudflared",
      "tag_pattern": "^\\d{4}\\.\\d+\\.\\d+$"
    }
  },
  {
    "name": "phasetwo-keycloak",
    "kind": "infra-compose",
    "compose_name": {{ keycloak_compose_name | default('keycloak') | to_json }},
    "service_key": "app",
    "upstream": {
      "source": "quay",
      "repo": "phasetwo/phasetwo-keycloak",
      "tag_pattern": "^\\d+\\.\\d+\\.\\d+$"
    }
  },
  {
    "name": "oauth2-proxy-staff",
    "kind": "infra-compose",
    "compose_name": {{ oauth2_proxy_staff_compose_name | default('oauth2-proxy-staff') | to_json }},
    "service_key": "app",
    "upstream": {
      "source": "quay",
      "repo": "oauth2-proxy/oauth2-proxy",
      "tag_pattern": "^v?\\d+\\.\\d+\\.\\d+-alpine$"
    }
  },
  {
    "name": "oauth2-proxy-admin",
    "kind": "infra-compose",
    "compose_name": {{ oauth2_proxy_admin_compose_name | default('oauth2-proxy-admin') | to_json }},
    "service_key": "app",
    "upstream": {
      "source": "quay",
      "repo": "oauth2-proxy/oauth2-proxy",
      "tag_pattern": "^v?\\d+\\.\\d+\\.\\d+-alpine$"
    }
  },
  {
    "name": "semaphore-db",
    "kind": "infra-compose",
    "compose_name": {{ semaphore_compose_name | default('semaphore') | to_json }},
    "service_key": "db",
    "upstream": {
      "source": "dockerhub",
      "repo": "library/postgres",
      "tag_pattern": "^16\\.\\d+(?:\\.\\d+)?-alpine$",
      "scheme": "partial_line"
    }
  }
]
