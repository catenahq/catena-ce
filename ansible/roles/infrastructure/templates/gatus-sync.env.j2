# {{ ansible_managed }}
# Config for /usr/local/bin/gatus-sync. 0600 root:root -- contains the
# Dokploy API key.
DOKPLOY_API_BASE={{ dokploy_api_base }}
DOKPLOY_API_KEY={{ vault_dokploy_api_key }}
DOKPLOY_INFRA_PROJECT={{ dokploy_project_name }}
GATUS_CONFIG_PATH={{ gatus_host_config_dir }}/50-dokploy-apps.yaml
# Infra endpoint generation (40-infra.yaml from gatus-infra-spec.json).
# version-check.json is OPTIONAL: when the Business managed-update module
# is licensed it populates this file and gatus-sync appends version info
# to endpoint NAMES; in Community the file is absent and the suffix is
# skipped (best-effort).
GATUS_INFRA_SPEC_PATH={{ gatus_infra_spec_path }}
GATUS_INFRA_CONFIG_PATH={{ gatus_host_config_dir }}/40-infra.yaml
VERSION_CHECK_PATH={{ version_check_output_file }}
# Regex to find the running Gatus container in `docker ps` output. Dokploy
# assigns names like `gatus-abcdef-app-1` (random 6-char hash).
GATUS_CONTAINER_NAME_RE=^{{ gatus_compose_name }}-[a-z0-9]+-app-1$
INFRA_COMPOSE_NAMES={{ gatus_compose_name }},{{ healthchecks_compose_name }},{{ keycloak_compose_name }},{{ recovery_compose_name }}
AUTH_HOSTNAME={{ keycloak_hostname }}
# Where gatus-sync writes its Homepage-widget summary JSON (best-effort;
# empty disables). Picked up by the homepage-stats nginx sidecar and
# exposed at http://homepage-stats/gatus-summary.json on dokploy-network.
GATUS_SUMMARY_PATH={{ gatus_summary_file }}
# Reach Gatus via its loopback-only published port, NOT the dokploy-network
# alias -- gatus-sync runs on the host and can't resolve container DNS.
GATUS_API_URL=http://127.0.0.1:{{ gatus_host_localhost_port }}
# Healthchecks summary (same pattern as GATUS_SUMMARY_PATH). Empty API
# key disables the probe -- set when vault_healthchecks_api_key_readonly
# is populated. Homepage customapi reads the summary to color the
# Healthchecks card red when any check is down.
HEALTHCHECKS_SUMMARY_PATH={{ healthchecks_summary_file }}
HEALTHCHECKS_API_URL=http://127.0.0.1:{{ healthchecks_host_localhost_port }}/api/v3/checks/
HEALTHCHECKS_API_KEY={{ vault_healthchecks_api_key_readonly | default('') }}
# Read-write key enables the orphan-pause pass at the end of gatus-sync:
# for every HC check named `gatus-*` whose endpoint isn't in the current
# Gatus config, POST /pause/. Readonly key can't pause, so we need a
# second key. Empty = orphan cleanup disabled (graceful upgrade path for
# vaults minted before this key existed).
HEALTHCHECKS_API_KEY_RW={{ vault_healthchecks_api_key_readwrite | default('') }}
