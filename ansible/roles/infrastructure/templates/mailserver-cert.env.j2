# {{ ansible_managed }}
# Per-host config for the mailserver cert deploy hook
# (/etc/letsencrypt/renewal-hooks/deploy/mailserver-reload.sh, installed
# from vps-scripts/mailserver-cert-reload.sh). The hook sources this so
# the executable itself carries no Jinja.
MAIL_HOSTNAME={{ mailserver_hostname }}
MAIL_CERT_LIVE_DIR={{ mailserver_cert_live_dir }}
