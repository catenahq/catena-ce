# Managed by Ansible (roles/backup). Do not edit by hand -- changes are
# overwritten. Consumed by {{ backup_wrapper_script }} and the systemd unit.
# Mode 0600, owner root: contains S3 credentials.

RESTIC_REPOSITORY={{ backup_restic_repo }}
RESTIC_PASSWORD_FILE={{ backup_password_file }}

# S3 credentials for the restic repo (the client-owned bucket).
AWS_ACCESS_KEY_ID={{ vault_backup_s3_access_key }}
AWS_SECRET_ACCESS_KEY={{ vault_backup_s3_secret_key }}

# Non-secret configuration used by the wrapper.
# R24: two pings per run. _URL = success-only (sliding-grace window).
# _ATTEMPTED_URL = every run start + /fail on hard errors.
BACKUP_HEALTHCHECK_URL={{ backup_healthcheck_url }}
BACKUP_HEALTHCHECK_ATTEMPTED_URL={{ backup_healthcheck_attempted_url }}
# R13: external dead-mans pinged in parallel at end-of-run on success.
# Either, both, or neither set is valid; empty values are skipped silently
# by run-backup.sh.
BACKUP_HEALTHCHECK_URL_CLIENT={{ backup_healthcheck_url_client }}
BACKUP_HEALTHCHECK_URL_OPERATOR={{ backup_healthcheck_url_operator }}

BACKUP_PG_DUMP_USER={{ backup_pg_dump_user }}
BACKUP_STAGING_DIR={{ storage_mount_point }}/backup-staging

# R16 disk-space preflight. run-backup.sh aborts loudly (no pg_dumpall,
# no restic) if the staging mount has fewer than this many free bytes.
BACKUP_PREFLIGHT_MIN_BYTES={{ backup_preflight_min_bytes }}
BACKUP_DISK_PREFLIGHT_SCRIPT={{ backup_disk_preflight_script }}

# Retention policy (restic forget --prune flags).
BACKUP_KEEP_HOURLY={{ backup_retention_policy.keep_hourly | default(24) }}
BACKUP_KEEP_DAILY={{ backup_retention_policy.keep_daily }}
BACKUP_KEEP_WEEKLY={{ backup_retention_policy.keep_weekly }}
BACKUP_KEEP_MONTHLY={{ backup_retention_policy.keep_monthly }}

# Sibling files hold list-valued config (paths + excludes) -- one item
# per line. Kept out of this env file because /bin/sh has no arrays and
# quote-packing a list into a scalar is its own footgun.
BACKUP_PATHS_FILE=/etc/catena/backup-paths
BACKUP_EXCLUDE_FILE=/etc/catena/backup-exclude-patterns

# Diagnostic outputs.
BACKUP_STATS_FILE={{ backup_stats_file }}
BACKUP_COVERAGE_SCRIPT={{ backup_coverage_script }}

# Snapshot export (OliveTin "Export latest snapshot" button).
BACKUP_EXPORT_DIR={{ backup_export_dir }}
BACKUP_EXPORT_KEEP_LAST={{ backup_export_keep_last }}
BACKUP_PASSWORD_FILE_PATH={{ backup_password_file }}
# Used only in the scp-hint line of the export script's stdout.
BACKUP_SCP_HINT_HOST={{ ansible_host | default(inventory_hostname) }}

# F6: snapshot-list helper. Renders ${BACKUP_EXPORT_DIR}/index.html
# after every backup run + every export so recovery.<zone>'s landing
# page tracks the live restic repo state.
BACKUP_SNAPSHOT_LIST_SCRIPT={{ backup_snapshot_list_script }}
# Surfaced in the rendered page's "Need a download?" callout. Dotted
# back through the env file so the script doesn't need a separate
# discovery path.
CLOUDFLARE_ZONE={{ cloudflare_zone | default('') }}
