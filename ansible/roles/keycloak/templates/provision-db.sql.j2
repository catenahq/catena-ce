-- {{ ansible_managed }}
-- Idempotent role + database provisioner for the Keycloak DB inside
-- dokploy-postgres. CREATE ROLE / CREATE DATABASE are not IF NOT EXISTS
-- in vanilla psql, so the role is wrapped in a DO block + pg_database
-- existence is guarded inline via SELECT.
\set ON_ERROR_STOP on

DO $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '{{ keycloak_db_user }}') THEN
    CREATE ROLE {{ keycloak_db_user }} LOGIN PASSWORD '{{ vault_keycloak_db_password | regex_replace("'", "''") }}';
  END IF;
END
$$;

-- Always rotate-align: ALTER USER ... PASSWORD is idempotent; pg_authid
-- records the same hash if unchanged. Drift between vault + DB surfaces
-- as auth failure on the next compose deploy, so this is the canonical
-- writer of the live password.
ALTER USER {{ keycloak_db_user }} WITH PASSWORD '{{ vault_keycloak_db_password | regex_replace("'", "''") }}';

-- CREATE DATABASE cannot run inside a transaction block, so it lives
-- outside the DO. The Ansible task that wraps this script gates
-- execution on a SELECT 1 FROM pg_database WHERE datname = ... probe;
-- that probe is what makes the create idempotent.
{% if keycloak_db_create | default(true) %}
CREATE DATABASE {{ keycloak_db_name }} OWNER {{ keycloak_db_user }};
{% endif %}
