#!/usr/bin/env python3
"""catena -- Community Catena installer / CLI.

A thin wrapper over the Ansible base so self-hosters never touch raw
ansible-playbook. Subcommands:

  install    seed config + secrets (reuses seed.py), then run
             preflight -> bootstrap -> site -> validate
  converge   re-run site.yml (apply config changes / new app tags)
  validate   run validate.yml (on-host + tailnet + external checks)
  restore    run restore.yml (in-place whole-host restore)
  recover    whole-host DR onto a FRESH replacement box: preflight ->
             bootstrap -> restore -> site -> validate (reuses the existing
             inventory's vault + .env; no seed)
  rollback   roll a STILL-RUNNING host back to a prior snapshot: preflight ->
             restore -> site -> validate (in place, no bootstrap)
  uninstall  hand control back to the OS: unmask + re-enable Debian's
             apt-daily-upgrade.timer (the unattended-upgrades handback)
             and print teardown guidance

The vault is SOPS-encrypted to your own age key. seed.py mints it on first
install and saves it to a key file; this CLI loads it into $SOPS_AGE_KEY
automatically on every run so the Ansible community.sops vars plugin can
decrypt. Run inside the catena-ce checkout:

    uv run ./catena install --inventory prod
"""
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

# This file lives at the root of the self-contained ansible/ tree.
ANSIBLE_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(ANSIBLE_DIR))

# The ordered converge chain a fresh install runs. preflight is a SEPARATE
# invocation BEFORE bootstrap so a stray --limit can never skip it.
INSTALL_CHAIN = ("preflight", "bootstrap", "site", "validate")

# Whole-host disaster recovery onto a FRESH replacement box: same as install
# but with `restore` inserted after bootstrap (push the last snapshot onto the
# new host before the converge), and no seed step (the existing inventory's
# vault + .env are reused). Mirrors the operator disaster_recovery flow.
RECOVER_CHAIN = ("preflight", "bootstrap", "restore", "site", "validate")

# Roll a STILL-RUNNING host back to a prior restic snapshot: restore in place
# then re-converge + validate. No bootstrap (the box is alive + on the
# tailnet). The `site` leg is load-bearing for password coherence
# (pg_password_reconcile re-aligns vault -> swarm secret -> pg_authid if the
# operator rotated a secret between snapshot and rollback) -- never drop it.
ROLLBACK_CHAIN = ("preflight", "restore", "site", "validate")

# Host binaries the wrapper shells out to. age-keygen + sops handle the
# vault; ansible-playbook/ansible run the base.
REQUIRED_BINARIES = ("ansible-playbook", "ansible", "sops", "age-keygen")


def _c(code: str, msg: str) -> str:
    return f"\033[{code}m{msg}\033[0m"


def banner(msg: str) -> None:
    print(_c("1;34", f"\n== {msg}"), file=sys.stderr)


def die(msg: str, code: int = 1) -> None:
    print(_c("1;31", f"x {msg}"), file=sys.stderr)
    raise SystemExit(code)


def check_prereqs(binaries: tuple[str, ...] = REQUIRED_BINARIES) -> list[str]:
    """Return the list of required binaries missing from PATH."""
    return [b for b in binaries if shutil.which(b) is None]


def ensure_age_key_env(key_file: Path | None = None) -> None:
    """Make sure $SOPS_AGE_KEY is set so the community.sops vars plugin can
    decrypt the vault. If it is unset, load it from the seed-written key
    file. Best-effort: if neither is available, downstream ansible fails
    with a clear sops error."""
    import seed  # local import: shares ANSIBLE_DIR on sys.path

    if os.environ.get("SOPS_AGE_KEY", "").strip():
        return
    key_file = key_file or seed.DEFAULT_AGE_KEY_FILE
    if not key_file.is_file():
        return
    from helpers import age_key
    secret = age_key.extract_secret(key_file.read_text())
    if secret:
        os.environ["SOPS_AGE_KEY"] = secret


def inventory_path(inventory: str) -> Path:
    return ANSIBLE_DIR / "inventory" / inventory


def playbook_cmd(inventory: str, playbook: str, extra: list[str] | None = None) -> list[str]:
    """Build the ansible-playbook argv for one stage. Pure (no side effects)
    so it is unit-testable."""
    cmd = [
        "ansible-playbook",
        "-i", str(inventory_path(inventory)),
        str(ANSIBLE_DIR / "playbooks" / f"{playbook}.yml"),
    ]
    if extra:
        cmd.extend(extra)
    return cmd


def _tags_extra(args: argparse.Namespace) -> list[str] | None:
    """Turn a `--tags a,b` CLI value into the ansible-playbook passthrough,
    or None when unset. Lets `converge`/`validate` run a tag-scoped subset
    (e.g. `catena converge --tags keycloak,oauth2_proxy` to re-apply only
    the auth roles after rotating a secret), Pure -- unit-testable."""
    tags = (getattr(args, "tags", "") or "").strip()
    return ["--tags", tags] if tags else None


def _snapshot_extra(args: argparse.Namespace) -> list[str] | None:
    """Turn a `--snapshot <id>` CLI value into the restore.yml extra-var
    passthrough (`-e restore_snapshot=<id>`), or None when unset (restore.yml
    then defaults to `latest`). Lets a self-hoster restore from a SPECIFIC
    restic snapshot, not just the most recent. Pure -- unit-testable."""
    snap = (getattr(args, "snapshot", "") or "").strip()
    return ["-e", f"restore_snapshot={snap}"] if snap else None


def _bootstrap_extra_vars(input_path: str | None) -> tuple[list[str], Path | None]:
    """Non-interactive bootstrap needs bootstrap_initial_user +
    bootstrap_root_password, but bootstrap.yml only collects them via a
    play-scoped vars_prompt (skipped with no TTY, so Phase 0.5 never installs
    the key and Phase 1 connects as the wrong/keyless user). Read them from
    the install.yaml and hand them to the bootstrap stage as extra-vars
    (highest precedence -> they satisfy the prompt across every play).

    The provider password is written to a 0600 temp file passed as `-e @file`
    (NOT `-e key=value`), so it never lands on argv, in `ps`, or in the
    printed command / bench logs. Returns (extra_args, tmp_path_to_clean).
    With no install.yaml the interactive vars_prompt handles it, so this is a
    no-op."""
    if not input_path:
        return [], None
    import seed  # shares ANSIBLE_DIR on sys.path
    import yaml

    host = (seed.load_input(Path(input_path)).get("host") or {})
    overrides: dict[str, str] = {
        # Blank password is meaningful: Phase 0.5 then skips key install (the
        # host is assumed already keyed), matching the vars_prompt default.
        "bootstrap_root_password": host.get("initial_password") or "",
    }
    if host.get("initial_user"):
        overrides["bootstrap_initial_user"] = host["initial_user"]

    fd, name = tempfile.mkstemp(prefix="catena-bootstrap-vars-", suffix=".yml")
    os.close(fd)
    tmp = Path(name)
    tmp.write_text(yaml.safe_dump(overrides, default_flow_style=False))
    tmp.chmod(0o600)
    return ["-e", f"@{tmp}"], tmp


def _run(cmd: list[str]) -> None:
    print(_c("1;30", "  $ " + " ".join(cmd)), file=sys.stderr)
    result = subprocess.run(cmd)
    if result.returncode != 0:
        die(f"command failed (exit {result.returncode}): {' '.join(cmd)}",
            code=result.returncode)


def _host_tailnet_ip(inventory: str) -> str:
    """Return the vps host's tailnet ansible_host from the inventory hosts.yml
    (folded in from .bootstrap-output.yml after the bootstrap stage by
    bootstrap_output.apply_to_inventory). Returns "" when absent or still the
    0.0.0.0 placeholder."""
    import yaml

    hosts_yml = inventory_path(inventory) / "hosts.yml"
    if not hosts_yml.is_file():
        return ""
    data = yaml.safe_load(hosts_yml.read_text()) or {}
    vps = (
        ((data.get("all") or {}).get("children") or {})
        .get("vps", {}).get("hosts") or {}
    )
    for entry in vps.values():
        ip = (entry or {}).get("ansible_host", "")
        if ip and ip != "0.0.0.0":
            return ip
    return ""


def _ensure_dokploy_api_key(inventory: str) -> bool:
    """Bridge between the two site passes a fresh install needs.

    After site pass 1 Dokploy is up, but the auth stack (Keycloak compose,
    oauth2-proxy per-app routes, the gated apps' Traefik chain) is all gated
    behind vault_dokploy_api_key -- which does not exist until an admin
    account is created and a key minted. helpers/bootstrap_dokploy_admin.py
    does that over better-auth's public endpoints (signup -> signin -> mint)
    and merges the key into the vault, so a SECOND site pass -- a fresh
    ansible process that re-reads the now-updated vault (community.sops caches
    decrypted vault contents per-process, so an in-place re-read would not see
    it) -- deploys the auth stack.

    Returns True when a key was minted (caller runs the second pass); False
    when the vault already held one (a single pass already deployed
    everything, e.g. a re-install over an existing inventory)."""
    from helpers import sops_vault

    inv = inventory_path(inventory)
    vault = inv / "group_vars" / "all" / "vault.sops.yml"
    if len(sops_vault.read_value(vault, "vault_dokploy_api_key")) > 10:
        return False
    tailnet_ip = _host_tailnet_ip(inventory)
    if not tailnet_ip:
        die("cannot mint the Dokploy API key: the host's tailnet IP is "
            "unknown (hosts.yml still has the 0.0.0.0 placeholder -- did "
            "bootstrap join the tailnet and emit .bootstrap-output.yml?).")
    banner("Bootstrap Dokploy admin + API key (unlocks the auth stack)")
    _run([
        sys.executable,
        str(ANSIBLE_DIR / "helpers" / "bootstrap_dokploy_admin.py"),
        "--vault", str(vault),
        "--env-file", str(inv / ".env"),
        "--tailnet-ip", tailnet_ip,
    ])
    return True


def ensure_collections() -> None:
    """Install the Galaxy collections (community.sops, community.general, ...)
    on first run if collections/ is absent."""
    req = ANSIBLE_DIR / "requirements.yml"
    coll = ANSIBLE_DIR / "collections"
    if coll.is_dir() or not req.is_file():
        return
    banner("Installing Ansible collections (first run)")
    _run([
        "ansible-galaxy", "collection", "install",
        "-r", str(req), "-p", str(coll),
    ])


def _preflight_checks() -> None:
    missing = check_prereqs()
    if missing:
        die(
            "missing required tools on PATH: " + ", ".join(missing) + "\n"
            "  - ansible-core: run this via `uv run ./catena ...`, or "
            "`pipx install ansible-core`\n"
            "  - sops + age: install from your package manager "
            "(https://github.com/getsops/sops, https://github.com/FiloSottile/age)"
        )


def _require_inventory(inventory: str) -> None:
    if not inventory_path(inventory).is_dir():
        die(
            f"inventory '{inventory}' not found at {inventory_path(inventory)}. "
            "Run `./catena install --inventory " + inventory + "` first."
        )


def _run_deploy_chain(
    inventory: str,
    chain: tuple[str, ...],
    *,
    bootstrap_extra: list[str] | None,
    restore_extra: list[str] | None = None,
) -> None:
    """Run an ordered deploy chain (install or recover) stage by stage,
    threading the bootstrap creds onto the bootstrap stage and (recover only)
    the restore snapshot onto the restore stage, plus the two inter-stage
    bridges a deploy needs:

      - after `bootstrap`: fold the steady-state tailnet IP that bootstrap
        emitted into .bootstrap-output.yml back into hosts.yml, so the later
        stages (each a separate ansible invocation) reach the host instead of
        the 0.0.0.0 placeholder.
      - after the first `site`: mint the Dokploy admin + API key if the vault
        lacks one, then run a SECOND site pass so the auth stack deploys
        before validate. On recovery the reused vault already holds the key,
        so this is a single pass.

    Shared by install + recover so the bridge logic lives in one place."""
    for stage in chain:
        banner(f"Stage: {stage}")
        if stage == "bootstrap":
            extra = bootstrap_extra
        elif stage == "restore":
            extra = restore_extra
        else:
            extra = None
        _run(playbook_cmd(inventory, stage, extra))
        if stage == "bootstrap":
            from helpers import bootstrap_output
            applied = bootstrap_output.apply_to_inventory(
                inventory_path(inventory)
            )
            for line in applied:
                print(_c("1;32", f"  + bootstrap-output applied {line}"),
                      file=sys.stderr)
        if stage == "site" and _ensure_dokploy_api_key(inventory):
            banner("Stage: site (pass 2 -- auth stack)")
            _run(playbook_cmd(inventory, "site"))


def cmd_install(args: argparse.Namespace) -> int:
    _preflight_checks()
    inventory = args.inventory or input("Inventory name [prod]: ").strip() or "prod"

    banner("Step 1/2 -- collect config + secrets (seed)")
    seed_cmd = [sys.executable, str(ANSIBLE_DIR / "seed.py"), "--inventory", inventory]
    if args.input:
        seed_cmd += ["-i", args.input]
    if args.no_confirm:
        seed_cmd += ["--no-confirm"]
    result = subprocess.run(seed_cmd)
    if result.returncode != 0:
        die(f"seed failed (exit {result.returncode}); nothing deployed.",
            code=result.returncode)

    # seed wrote / used the age key; load it so ansible can decrypt the vault.
    ensure_age_key_env()
    ensure_collections()

    banner("Step 2/2 -- deploy (preflight -> bootstrap -> site -> validate)")
    bootstrap_extra, bootstrap_vars_tmp = _bootstrap_extra_vars(args.input)
    try:
        _run_deploy_chain(inventory, INSTALL_CHAIN, bootstrap_extra=bootstrap_extra)
    finally:
        if bootstrap_vars_tmp is not None:
            bootstrap_vars_tmp.unlink(missing_ok=True)
    banner("Install complete.")
    return 0


def cmd_recover(args: argparse.Namespace) -> int:
    """Whole-host disaster recovery onto a FRESH replacement box, reusing the
    existing inventory's vault + .env (no seed): preflight -> bootstrap ->
    restore -> site -> validate. The provider creds come from --input
    install.yaml (same 0600-temp-file path as install, never on argv);
    --snapshot picks the restic snapshot to push (default: latest)."""
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()

    banner("Recover -- preflight -> bootstrap -> restore -> site -> validate")
    bootstrap_extra, bootstrap_vars_tmp = _bootstrap_extra_vars(args.input)
    restore_extra = _snapshot_extra(args)
    try:
        _run_deploy_chain(
            args.inventory, RECOVER_CHAIN,
            bootstrap_extra=bootstrap_extra, restore_extra=restore_extra,
        )
    finally:
        if bootstrap_vars_tmp is not None:
            bootstrap_vars_tmp.unlink(missing_ok=True)
    banner("Recovery complete.")
    return 0


def cmd_rollback(args: argparse.Namespace) -> int:
    """Roll a still-running host back to a prior restic snapshot: preflight ->
    restore -> site -> validate, in place (no bootstrap). Reuses the existing
    inventory's vault. --snapshot picks the restic snapshot to roll back to
    (default: latest). The `site` leg is load-bearing for password coherence
    (pg_password_reconcile) -- never dropped."""
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()

    banner("Rollback -- preflight -> restore -> site -> validate")
    _run_deploy_chain(
        args.inventory, ROLLBACK_CHAIN,
        bootstrap_extra=None, restore_extra=_snapshot_extra(args),
    )
    banner("Rollback complete.")
    return 0


def cmd_converge(args: argparse.Namespace) -> int:
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()
    _run(playbook_cmd(args.inventory, "site", _tags_extra(args)))
    return 0


def cmd_validate(args: argparse.Namespace) -> int:
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()
    _run(playbook_cmd(args.inventory, "validate", _tags_extra(args)))
    return 0


def cmd_restore(args: argparse.Namespace) -> int:
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()
    _run(playbook_cmd(args.inventory, "restore", _snapshot_extra(args)))
    return 0


def cmd_uninstall(args: argparse.Namespace) -> int:
    _preflight_checks()
    _require_inventory(args.inventory)
    ensure_age_key_env()
    ensure_collections()
    banner("Uninstall -- hand unattended-upgrades back to Debian")
    _run(playbook_cmd(args.inventory, "uninstall"))
    return 0


def build_parser() -> argparse.ArgumentParser:
    ap = argparse.ArgumentParser(
        prog="catena",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = ap.add_subparsers(dest="command", required=True)

    p_install = sub.add_parser("install", help="seed + preflight/bootstrap/site/validate")
    p_install.add_argument("--inventory", help="inventory name (prompted if omitted)")
    p_install.add_argument("-i", "--input", help="install.yaml for non-interactive values")
    p_install.add_argument("--no-confirm", action="store_true",
                           help="skip seed confirmation + one-shot secret prompts")
    p_install.set_defaults(func=cmd_install)

    p_conv = sub.add_parser("converge", help="re-run site.yml")
    p_conv.add_argument("--inventory", required=True)
    p_conv.add_argument("--tags", default="",
                        help="comma-separated ansible tags to scope the "
                             "converge (e.g. keycloak,oauth2_proxy)")
    p_conv.set_defaults(func=cmd_converge)

    p_val = sub.add_parser("validate", help="run validate.yml")
    p_val.add_argument("--inventory", required=True)
    p_val.add_argument("--tags", default="",
                       help="comma-separated ansible tags to scope validation")
    p_val.set_defaults(func=cmd_validate)

    p_res = sub.add_parser("restore", help="run restore.yml (in-place restore)")
    p_res.add_argument("--inventory", required=True)
    p_res.add_argument("--snapshot", default="",
                       help="restic snapshot id to restore (default: latest)")
    p_res.set_defaults(func=cmd_restore)

    p_rec = sub.add_parser(
        "recover",
        help="whole-host DR onto a fresh replacement box "
             "(bootstrap -> restore -> site -> validate)",
    )
    p_rec.add_argument("--inventory", required=True)
    p_rec.add_argument("-i", "--input",
                       help="install.yaml supplying the replacement box's "
                            "provider user + password for bootstrap")
    p_rec.add_argument("--snapshot", default="",
                       help="restic snapshot id to restore (default: latest)")
    p_rec.set_defaults(func=cmd_recover)

    p_rb = sub.add_parser(
        "rollback",
        help="roll a running host back to a prior snapshot "
             "(restore -> site -> validate, in place)",
    )
    p_rb.add_argument("--inventory", required=True)
    p_rb.add_argument("--snapshot", default="",
                      help="restic snapshot id to roll back to (default: latest)")
    p_rb.set_defaults(func=cmd_rollback)

    p_uni = sub.add_parser(
        "uninstall",
        help="hand unattended-upgrades back to the OS + print teardown guidance",
    )
    p_uni.add_argument("--inventory", required=True)
    p_uni.set_defaults(func=cmd_uninstall)

    return ap


def main(argv: list[str] | None = None) -> int:
    # Run from the ansible/ dir so ansible.cfg + relative inventory/playbook
    # paths resolve regardless of where the user invoked us.
    os.chdir(ANSIBLE_DIR)
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("\nCancelled (interrupted).", file=sys.stderr)
        raise SystemExit(130)
