# ─── catena: operator-editable, non-secret configuration ──────────────
#
# Copy to .env in this same directory (gitignored) and fill in. Per-inventory
# so multiple hosts can coexist in one checkout: inventory/example/.env,
# inventory/clientco/.env, etc.
# Secrets live in inventory/<name>/group_vars/all/vault.sops.yml (SOPS-encrypted to age recipients).
# Inventory (VPS IPs, tailnet hostnames) lives in inventory/<name>/hosts.yml.
#
# Loaded by Ansible via the custom `dotenv` lookup plugin at playbooks/lookup_plugins/,
# which resolves <inventory_dir>/.env automatically.
# Group_vars reference values with  "{{ lookup('dotenv', 'KEY') }}".

# ─── SSH ──────────────────────────────────────────────────────────────────
# Dedicated Ed25519 keypair for this project (generate once on your laptop):
#     ssh-keygen -t ed25519 -f ~/.ssh/catena_ed25519 -C catena
SSH_PRIVATE_KEY=~/.ssh/catena_ed25519
SSH_PUBLIC_KEY_FILE=~/.ssh/catena_ed25519.pub

# Non-root user created on every VPS. Your public key is authorized for it.
OPS_USER=ops

# ─── Client-facing language default ────────────────────────────────────────
# Applies to the docs wiki, catena-admin, and Keycloak login UI. Values: en | fr.
CATENA_DEFAULT_LANGUAGE=en

# ─── Tailscale ────────────────────────────────────────────────────────────
# Comma-separated tags advertised by each VPS. tag:vps is required (the OAuth
# client is scoped to it). To add more tags you MUST first authorize them in
# BOTH places, otherwise the OAuth API rejects key minting with a 400:
#   1. Tailscale admin console -> Access controls -> tagOwners -> add the tag
#   2. Tailscale admin console -> Settings -> OAuth client -> add the tag to scope
TAILSCALE_TAGS=tag:vps

# Let Tailscale override systemd-resolved? Usually false -- we keep control of DNS.
TAILSCALE_ACCEPT_DNS=false

# ─── Cloudflare ────────────────────────────────────────────────────────
CLOUDFLARE_ZONE=example.com
CLOUDFLARE_ACCOUNT_ID=REPLACE

# Public-facing subdomains, joined with CLOUDFLARE_ZONE. All gated by
# self-hosted SSO + forward-auth (Keycloak + oauth2-proxy); SSO works across
# them via the shared *.<zone> cookie.
#   apps.<zone>      -> Dokploy UI (override DOKPLOY_ADMIN_SUBDOMAIN to `admin`)
#   monitor.<zone>   -> Gatus (live probes + public status page)
#   dash.<zone>      -> catena-admin (per-VPS admin panel: Apps / System /
#                       Actions / Recovery; runs the host dispatcher)
#   heartbeat.<zone> -> Healthchecks (cron / dead-man monitoring)
DOKPLOY_ADMIN_SUBDOMAIN=apps
DOKPLOY_MONITOR_SUBDOMAIN=monitor
DOKPLOY_DASH_SUBDOMAIN=dash
HEARTBEAT_SUBDOMAIN=heartbeat
# Keycloak SSO lives at AUTH_SUBDOMAIN.<zone>. Clients log in here once;
# SSO-forwarded to the subdomains above via oauth2-proxy.
AUTH_SUBDOMAIN=auth

# Optional prefix prepended to every Cloudflare tunnel name. Default empty --
# each host owns one tunnel named after its inventory hostname.
CLOUDFLARED_TUNNEL_NAME_PREFIX=

# ─── Admin identity (shared by Dokploy + Keycloak) ────────────────────────
# Single email used for both the Dokploy admin account and the initial
# Keycloak realm admin. The matching password lives in vault.sops.yml as
# vault_admin_password. First-login URLs:
#   - Dokploy:  https://apps.<zone>   (or DOKPLOY_ADMIN_SUBDOMAIN)
#   - Keycloak: https://auth.<zone>
ADMIN_EMAIL=operator@example.com

# ─── SMTP (outbound mail for Keycloak: password reset, invites, MFA) ──────
# Three modes -- pick ONE (or leave all blank to deploy without mail).
#
# Mode A (Resend, recommended). Sign up at resend.com, verify your sending
# domain (add DKIM/SPF/DMARC in Cloudflare), generate ONE API key (re_...).
# Store it in vault_smtp_password -- it doubles as the SMTP password. Set only
# the sender email below; the role auto-resolves host/port/user
# (smtp.resend.com:587, user=resend). Free tier: 100/day, 3000/month.
RESEND_SENDER_EMAIL=
#
# Mode B (Brevo). Higher daily volume (300/day, 9k/month free). Requires the
# Brevo SMTP key (NOT the v3 API key) in vault_smtp_password. Only set the
# sender email below; host/port/user auto-resolved
# (smtp-relay.brevo.com:587, user=<the sender email>).
BREVO_SENDER_EMAIL=
#
# Mode C (manual -- any other SMTP provider or self-hosted).
# Ignored when Resend or Brevo sender is set above.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=auth@example.com
SMTP_USE_TLS=true

# ─── ntfy (Gatus alerting) ────────────────────────────────────────────────
# Where Gatus sends uptime alerts. Single topic per VPS, with the failing
# endpoint name embedded in every message. Defaults point at ntfy.sh (public,
# unauth). Self-host ntfy for a sovereign setup and override both values.
# Topic MUST be hard to guess -- anyone who knows it can spam the subscriber.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=REPLACE-UNIQUE-HARD-TO-GUESS-STRING

# ─── Storage (roles/storage) ──────────────────────────────────────────────
# built_in = single SSD (default). attached = a block volume (OVH Public
# Cloud, Hetzner Volume, DO Block Storage, etc.).
STORAGE_MODE=built_in
STORAGE_MOUNT_POINT=/mnt/data
STORAGE_BLOCK_DEVICE=/dev/sdb
STORAGE_BULK_ENABLED=false
STORAGE_BULK_MOUNT_POINT=/mnt/bulk

# ─── Docker ──────────────────────────────────────────────────────────────
# Optional pull-through Docker Hub mirror. Empty = pull from docker.io
# directly. Set to a mirror base URL (scheme + host + port) to route pulls
# through a cache.
DOCKER_REGISTRY_MIRROR_URL=

# ─── Apt cache ───────────────────────────────────────────────────────────
# Optional apt HTTP proxy (typically apt-cacher-ng). Empty = apt pulls direct.
# Set to the proxy URL (e.g. http://10.0.0.1:3142) to route HTTP apt traffic
# through it. HTTPS sources (docker-ce, tailscale) stay direct.
APT_PROXY_URL=

# ─── Dokploy ─────────────────────────────────────────────────────────────
# Version is pinned in roles/dokploy/defaults/main.yml. Override per-host in
# group_vars/all/main.yml if needed (set dokploy_version).
DOKPLOY_BIND_INTERFACE=tailscale0
DOKPLOY_PORT=3000

# Name of the Dokploy project where infrastructure services (Gatus,
# Healthchecks, catena-admin, Keycloak) live. Auto-created by
# roles/infrastructure if it doesn't exist.
DOKPLOY_PROJECT_NAME=infrastructure

# ─── Backup (roles/backup) ────────────────────────────────────────────────
# Restic repo on CLIENT-OWNED S3-compatible storage. Restic password goes in
# vault.sops.yml as vault_backup_restic_password.
#
# Community ships a MANUAL backup: run-backup runs on demand (the catena-admin
# "Backup now" action, `systemctl start catena-backup.service`, or your own
# cron). There is no built-in schedule. The offsite/immutable cold mirror +
# automated hourly/daily cadence + tested-restore attestation are the
# Business managed-backup tier.
BACKUP_RESTIC_REPO=s3:s3.example-region.example.net/<client>-restic
# Retention for `restic forget --prune` (applied whenever a backup runs).
BACKUP_KEEP_HOURLY=24
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6
# Optional Healthchecks ping URL for the manual backup. Defaults to the local
# self-hosted Healthchecks at heartbeat.<zone> (the check appears on first
# backup run). Point at an OFF-HOST endpoint (e.g. healthchecks.io free tier)
# if you want whole-host-outage coverage. Empty = no ping.
BACKUP_HEALTHCHECK_URL=

# ─── Nextcloud per-file version retention ─────────────────────────────────
# Direct lever on bucket storage cost. Default `auto, 7` keeps ~50-70% less
# storage than the upstream 30-day cap; bump to `auto, 14` / `auto, 30` for
# deeper undo. Flows through the zz-catena.sh entrypoint hook into Nextcloud's
# versions_retention_obligation on every container start.
NEXTCLOUD_VERSIONS_RETENTION=auto, 7

# ─── Locale / timezone ───────────────────────────────────────────────────
COMMON_TIMEZONE=America/Toronto
COMMON_LOCALE=en_CA.UTF-8

# ─── Beszel resource monitor -- off by default ────────────────────────────
# Hub + agent resource monitor (per-container + per-host CPU/memory/network/
# disk history with threshold alerting). When BESZEL_ENABLED=true the hub is
# published at <BESZEL_SUBDOMAIN>.<zone>, admin-gated by oauth2-proxy; the
# catena-admin Resources tab links to it. Threshold alerts ride the
# Healthchecks notification plane via the beszel-hc-shim sidecar.
BESZEL_ENABLED=false
BESZEL_SUBDOMAIN=hub

# ─── coturn TLS cert source ─────────────────────────────────────────
# Issue the coturn TLS-TURN cert from Let's Encrypt's STAGING CA when true.
# Staging has no rate limit and is functionally identical for coturn (which
# only validates presence + expiry). NEVER set true in production -- browsers
# and TURN clients reject staging certs.
COTURN_CERTBOT_STAGING=false

# ─── mailserver TLS cert source ─────────────────────────────────────
# Same as COTURN_CERTBOT_STAGING, for the self-hosted mailserver's mail.<zone>
# cert. NEVER set true in production -- sending MTAs reject staging certs and
# deliverability breaks.
MAILSERVER_CERTBOT_STAGING=false
