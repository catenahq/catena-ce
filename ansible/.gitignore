# Real inventories carry a SOPS-encrypted vault.sops.yml (the crown jewels)
# plus a .env -- never commit them. Only the shipped example is tracked.
inventory/*
!inventory/example/

# Defense-in-depth: even inside the tracked example dir, never commit the
# real secret-bearing files (only the .example templates are tracked). If
# someone copies .env.example -> .env in place to test, it stays out of git.
inventory/example/.env
inventory/example/.bootstrap-output.yml
inventory/example/**/vault.sops.yml
inventory/example/**/vault.yml

# Galaxy collections vendored by `ansible-galaxy collection install -r requirements.yml`.
collections/

# Controller-side ansible state + python bytecode from the filter/lookup plugins.
.ansible/
**/__pycache__/
*.pyc
