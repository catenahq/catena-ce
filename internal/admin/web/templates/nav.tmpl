{{- /* CE renders only the CE tabs. The EE tabs (Access / Daily / Clients)
       are gated behind per-tab globals that default false in Community --
       a license-loaded EE plugin flips them on when it contributes the
       tab (M2.5 plugin nav registry), so a CE-only host shows no dead
       links. */ -}}
{{define "nav"}}
<a href="/apps"{{ if or (eq .Path "/") (hasPrefix .Path "/apps") }} class="active"{{ end }}>{{ .T "tabs.apps" }}</a>
{{- if .IsAdmin }}
{{- if .Globals.access_tab_enabled }}
<a href="/access"{{ if hasPrefix .Path "/access" }} class="active"{{ end }}>{{ .T "tabs.access" }}</a>
{{- end }}
<a href="/system"{{ if or (hasPrefix .Path "/system") (hasPrefix .Path "/audit") }} class="active"{{ end }}>{{ .T "tabs.system" }}</a>
{{- if .Globals.daily_tab_enabled }}
<a href="/daily"{{ if hasPrefix .Path "/daily" }} class="active"{{ end }}>{{ .T "tabs.daily" }}</a>
{{- end }}
<a href="/maintenance"{{ if hasPrefix .Path "/maintenance" }} class="active"{{ end }}>{{ .T "tabs.maintenance" }}</a>
<a href="/resources"{{ if hasPrefix .Path "/resources" }} class="active"{{ end }}>{{ .T "tabs.resources" }}</a>
<a href="/actions"{{ if hasPrefix .Path "/actions" }} class="active"{{ end }}>{{ .T "tabs.actions" }}</a>
<a href="/recovery"{{ if hasPrefix .Path "/recovery" }} class="active"{{ end }}>{{ .T "tabs.recovery" }}</a>
{{- if .Globals.clients_tab_enabled }}
<a href="/clients"{{ if hasPrefix .Path "/clients" }} class="active"{{ end }}>{{ .T "tabs.clients" }}</a>
{{- end }}
{{- /* License-gated EE plugin panels contribute their own nav links at
       runtime (M2.5): present only while a Business license is active and the
       plugin binary is loaded, so a CE-only host shows none. */ -}}
{{- range .Plugins }}
<a href="/plugin/{{ .ID }}"{{ if hasPrefix $.Path (printf "/plugin/%s" .ID) }} class="active"{{ end }}>{{ .Title }}</a>
{{- end }}
{{- end }}
{{ end }}
