{{define "run_panel"}}
<div
  class="run-panel"
  hx-ext="sse"
  sse-connect="{{ .Data.StreamURL }}"
  sse-close="end"
>
  <div class="run-meta muted">
    <span class="run-action">{{ .Data.ActionName }}</span>
    <span class="run-status" sse-swap="start"></span>
  </div>
  <pre class="run-stream" sse-swap="message" hx-swap="beforeend"></pre>
  <pre class="run-stderr" sse-swap="stderr" hx-swap="beforeend"></pre>
  <div class="run-end" sse-swap="end" hx-swap="innerHTML"></div>
</div>
{{end}}
